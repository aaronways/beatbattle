# ── Server env vars ──
# In production, set these on your host (Render/Fly/Railway dashboard).
# Locally, copy this to `.env` (not committed) or just export them in your shell.

# Port the HTTP server listens on. Render injects PORT automatically; leave
# this unset on Render. Set it for local dev if 3001 is taken.
PORT=3001

# Comma-separated list of allowed client origins for CORS. REQUIRED in prod —
# leaving it unset accepts any origin, which is fine in dev but a hole in prod.
# Example: https://beatbattle.vercel.app
# Example with multiple: https://beatbattle.vercel.app,https://beatbattle.com
CLIENT_ORIGIN=

# Optional — shorten battle phase for fast iteration during development.
# Default is 600 (10 min). 60 is good for testing the full match loop quickly.
# BATTLE_SECONDS=60

# Where to store the persistent JSON file (leaderboard, ELO, match history).
# Default is ./.data relative to the server folder. On Render with a mounted
# disk, set this to the disk's mount path (typically /var/data). Without a
# persistent disk on Render free tier, files get wiped on every redeploy.
# DATA_DIR=/var/data
